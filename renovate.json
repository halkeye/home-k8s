{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    "replacements:all",
    "abandonments:recommended",
    "group:all",
    "group:immichMonorepo",
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":semanticCommits",
    ":automergeDigest",
    ":automergeBranch",
    ":timezone(America/Vancouver)",
    "helpers:pinGitHubActionDigests"
  ],
  "minimumReleaseAge": "1 days",
  "customDatasources": {
    "grafana-dashboards": {
      "defaultRegistryUrlTemplate": "https://grafana.com/api/dashboards/{{packageName}}",
      "format": "json",
      "transformTemplates": [
        "{\"releases\":[{\"version\": $string(revision)}], \"sourceDirectory\": name}"
      ]
    }
  },
  "customManagers": [
    {
      "description": "Process Grafana dashboards",
      "customType": "regex",
      "managerFilePatterns": [
        "/dashboards(-\\w+)?\\.yaml$/"
      ],
      "matchStrings": [
        "dashboards\\/(?<depName>\\d+)\\/revisions\\/(?<currentValue>\\d+)\\/download"
      ],
      "datasourceTemplate": "custom.grafana-dashboards",
      "versioningTemplate": "regex:^(?<major>\\d+)$",
      "autoReplaceStringTemplate": "dashboards/{{depName}}/revisions/{{newValue}}/download"
    },
    {
      "customType": "regex",
      "description": "Process Kustomization CRD dependencies - Image and Github Release are the same version",
      "managerFilePatterns": [
        "/kustomization.yaml/"
      ],
      "matchStrings": [
        "datasource=(?<datasource>\\S+) image=(?<depName>\\S+)\n.*?-\\s(.*?)/(?<currentValue>[^/]+)/[^/]+\n"
      ],
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}docker{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Process custom dependencies",
      "managerFilePatterns": [
        "/inventory/group_vars/all.yml/",
        "/(^|/)charts/.+\\.ya?ml(?:\\.j2)?$/",
        "/(^|/)charts/system-upgrade-controller/templates/(agent|server).yaml/"
      ],
      "matchStrings": [
        "(?<indentation>\\s*)(?<version_prefix>\\w*)(?<version_word>version|tag): \"(?<currentValue>[^\"]+)\" # renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)"
      ],
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "description": "Loose versioning for non-semver packages",
      "matchDatasources": [
        "docker"
      ],
      "versioning": "loose",
      "matchPackageNames": [
        "/prowlarr-develop/",
        "/docker-gathio/",
        "/docker-mautrix-signal/",
        "/docker-mautrix-whatsapp/",
        "/docker-mautrix-gmessages/",
        "/docker-n8n/",
        "/docker-yourls/",
        "/kavita/",
        "/searxng/"
      ]
    },
    {
      "matchPackageNames": [
        "felddy/foundryvtt"
      ],
      "allowedVersions": "< 13.0.0"
    },
    {
      "allowedVersions": "<9.0.0",
      "matchPackageNames": [
        "lmscommunity/logitechmediaserver"
      ]
    },
    {
      "matchPackageNames": [
        "/external-dns/",
        "/nginx/"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "/sops-secrets-operator/"
      ],
      "matchDatasources": [
        "helm"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "/karakeep/"
      ],
      "allowedVersions": "!/^0.27.0$/"
    },
    {
      "matchPackageNames": [
        "/system-upgrade-controller/"
      ],
      "allowedVersions": "!/^v0.20.0$/"
    },
    {
      "groupName": "mariadb-operator",
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "mariadb-operator-crds",
        "mariadb-operator",
        "mariadb-cluster"
      ]
    },
    {
      "addLabels": [
        "renovate/grafana-dashboard"
      ],
      "automerge": true,
      "automergeType": "branch",
      "commitMessageExtra": "( {{currentVersion}} ➔ {{newVersion}} )",
      "commitMessageTopic": "dashboard {{sourceDirectory}}",
      "ignoreTests": true,
      "matchDatasources": [
        "custom.grafana-dashboards"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "semanticCommitScope": "grafana-dashboards",
      "semanticCommitType": "chore"
    }
  ]
}
